*.sln
*.swp

# Operating System files
Thumbs.db
db.db
ehthumbs.db
Desktop.ini
.DS_Store

# Gemini Assistant Temporary Files
.gemini/

# Gradle Build & Cache Files (Crucial to avoid filename too long errors)
.gradle/
build/
